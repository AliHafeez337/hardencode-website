{
  "name": "hardencode-website",
  "compatibility_date": "2026-07-16",
  "main": "./worker.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "CONTACT_TO": "hello@hardencode.com",
    "CONTACT_FROM": "Hardencode <onboarding@resend.dev>"
  },
  "secrets": {
    "required": ["RESEND_API_KEY"]
  }
}
